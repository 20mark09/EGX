  "td:\u0628\u0627\u064a\u0648\u0646\u064a\u0631\u0632 \u0628\u0631\u0648\u0628\u0631\u062a\u064a\u0632 \u0644\u0644\u062a\u0646\u0645\u064a\u0629 \u0627\u0644\u0639\u0645\u0631\u0627\u0646\u064a\u0629 \u0628\u064a \u0627\u0631 \u0627\u064a \u062c\u0631\u0648\u0628 (PRDC.CA) - \u0646\u0645\u0648\u0630\u062c \u062a\u0642\u0631\u064a\u0631 \u0625\u0641\u0635\u0627\u062d \u0644\u0644\u0634\u0631\u0643\u0629 \u0639\u0646 \u0645\u062c\u0644\u0633 \u0627\u0644\u0625\u062f\u0627\u0631\u0629 \u0648\u0647\u064a\u0643\u0644 \u0627\u0644\u0645\u0633\u0627\u0647\u0645\u064a\u0646|15/07/2026",
  "td:\u0628\u064a \u0627\u064a \u062f\u064a - \u0627\u0644\u0628\u062f\u0631 \u0644\u0644\u0627\u0633\u062a\u062b\u0645\u0627\u0631 \u0648\u0627\u0644\u062a\u0646\u0645\u064a\u0629 (BIDI.CA) \u0625\u0639\u0627\u062f\u0629 \u062a\u0639\u0627\u0645\u0644|15/07/2026",
  "td:\u062a\u0633\u0648\u064a\u0629 \u0639\u062f\u062f \u0645\u0646 \u0648\u062b\u0627\u0626\u0642 \u0635\u0646\u062f\u0648\u0642 \u0627\u0644\u0645\u0624\u0634\u0631|15/07/2026",
  "td:\u062a\u0639\u0627\u0645\u0644\u0627\u062a \u0627\u0644\u062f\u0627\u062e\u0644\u064a\u064a\u0646 \u0648\u0627\u0644\u0645\u0633\u0627\u0647\u0645\u064a\u0646 \u0627\u0644\u0631\u0626\u064a\u0633\u064a\u064a\u0646 \u0648\u0627\u0644\u0645\u062c\u0645\u0648\u0639\u0627\u062a \u0627\u0644\u0645\u0631\u062a\u0628\u0637\u0629 \u0628\u0647\u0645 \u0628\u0627\u0644\u0634\u0631\u0643\u0627\u062a \u0627\u0644\u0645\u0642\u064a\u062f \u0644\u0647\u0627 \u0627\u0648\u0631\u0627\u0642 \u0645\u0627\u0644\u064a\u0629 \u0628\u062c\u062f\u0627\u0648\u0644 \u0627\u0644\u0628\u0648\u0631\u0635\u0629 \u062e\u0644\u0627\u0644 \u062c\u0644\u0633\u0629 14/07/2026|15/07/2026",
  "td:\u062a\u0645 \u0627\u064a\u0642\u0627\u0641 \u0627\u0644\u0648\u0631\u0642\u0629 \u0627\u0644\u0645\u0627\u0644\u064a\u0629 - EGS221U1C016 -  \u0627\u0644\u0641\u0646\u0627\u0631 \u0644\u0644\u0645\u0642\u0627\u0648\u0644\u0627\u062a \u0627\u0644\u0639\u0645\u0648\u0645\u064a\u0629 \u0648\u0627\u0644\u0625\u0646\u0634\u0627\u0621\u0627\u062a \u0648\u0627\u0644\u062a\u062c\u0627\u0631\u0629 \u0648\u0627\u0644\u0627\u0633\u062a\u064a\u0631\u0627\u062f \u0644\u0645\u062f\u0629 10 \u062f\u0642\u0627\u0626\u0642 \u0644\u062a\u062c\u0627\u0648\u0632\u0647\u0627 \u0646\u0633\u0628\u0629 5%|15/07/2026",
