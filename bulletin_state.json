  "td:\u0645\u0635\u0631 \u0627\u0644\u062c\u062f\u064a\u062f\u0629 \u0644\u0644\u0627\u0633\u0643\u0627\u0646 \u0648\u0627\u0644\u062a\u0639\u0645\u064a\u0631 (HELI.CA) \u0642\u0631\u0627\u0631\u0627\u062a \u0645\u062c\u0644\u0633 \u0627\u062f\u0627\u0631\u0629 \u0627\u0644\u0634\u0631\u0643\u0629 \u0628\u062c\u0644\u0633\u062a\u0647 \u0627\u0644\u0645\u0646\u0639\u0642\u062f\u0629 \u0628\u062a\u0627\u0631\u064a\u062e 18/07/2026|19/07/2026",
