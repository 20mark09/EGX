  "td:\u0627\u0644\u0645\u0635\u0631\u064a\u0629 \u0644\u062e\u062f\u0645\u0627\u062a \u0627\u0644\u0646\u0642\u0644 \u0648\u0627\u0644\u062a\u062c\u0627\u0631\u0629 \u0627\u064a\u062c\u064a\u062a\u0631\u0627\u0646\u0633 \u0646\u0648\u0633\u0643\u0648 (ETRS.CA) \u062a\u0648\u0632\u064a\u0639 \u0646\u0642\u062f\u0649|15/07/2026",
