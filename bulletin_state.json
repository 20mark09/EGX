  "td:\u0627\u0644\u0645\u062c\u0645\u0648\u0639\u0629 \u0627\u0644\u0645\u062a\u0643\u0627\u0645\u0644\u0629 \u0644\u0644\u0623\u0639\u0645\u0627\u0644 \u0627\u0644\u0647\u0646\u062f\u0633\u064a\u0629 (INEG.CA) \u0645\u062d\u0636\u0631 \u0627\u062c\u062a\u0645\u0627\u0639 \u0645\u062c\u0644\u0633 \u0627\u062f\u0627\u0631\u0629 \u0627\u0644\u0634\u0631\u0643\u0629 (\u0633\u0648\u0642 \u0627\u0644\u0634\u0631\u0643\u0627\u062a \u0627\u0644\u0635\u063a\u064a\u0631\u0629 \u0648\u0627\u0644\u0645\u062a\u0648\u0633\u0637\u0629)|15/07/2026",
  "td:\u0627\u0644\u0645\u062c\u0645\u0648\u0639\u0647 \u0627\u0644\u0645\u0635\u0631\u064a\u0647 \u0627\u0644\u0639\u0642\u0627\u0631\u064a\u0647 (AREH.CA) \u0628\u064a\u0627\u0646 \u0645\u0646 \u0627\u0644\u0634\u0631\u0643\u0629|15/07/2026",
