  "td:\u062a\u0645 \u0627\u064a\u0642\u0627\u0641 \u0627\u0644\u0648\u0631\u0642\u0629 \u0627\u0644\u0645\u0627\u0644\u064a\u0629 - EGS72201C014 -  \u0627\u0644\u0642\u0627\u0647\u0631\u0629 \u0644\u0644\u062e\u062f\u0645\u0627\u062a \u0627\u0644\u062a\u0639\u0644\u064a\u0645\u064a\u0629 \u0644\u0645\u062f\u0629 10 \u062f\u0642\u0627\u0626\u0642 \u0644\u062a\u062c\u0627\u0648\u0632\u0647\u0627 \u0646\u0633\u0628\u0629 10 %|15/07/2026",
