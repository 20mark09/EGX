  "td:\u0641\u064a\u0648\u062a\u0634\u0631 \u0643\u064a\u0631 \u0644\u0644\u0635\u0646\u0627\u0639\u0627\u062a \u0627\u0644\u0637\u0628\u064a\u0629 (FCMD.CA) \u0627\u0644\u0642\u0648\u0627\u0626\u0645 \u0627\u0644\u0645\u0627\u0644\u064a\u0629 \u0627\u0644\u0645\u0633\u062a\u0642\u0644\u0629|14/07/2026",
  "td:\u0641\u064a\u0648\u062a\u0634\u0631 \u0643\u064a\u0631 \u0644\u0644\u0635\u0646\u0627\u0639\u0627\u062a \u0627\u0644\u0637\u0628\u064a\u0629 (FCMD.CA) \u0645\u0644\u062e\u0635 \u0642\u0631\u0627\u0631\u0627\u062a \u0645\u062c\u0644\u0633 \u0627\u062f\u0627\u0631\u0629 \u0627\u0644\u0634\u0631\u0643\u0629|14/07/2026",
  "td:\u0642\u064a\u062f \u0633\u0646\u062f\u0627\u062a \u0627\u0644\u062e\u0632\u0627\u0646\u0629 \u0627\u0644\u0645\u0635\u0631\u064a\u0629|14/07/2026",
  "td:\u0643\u0648\u0646\u0643\u0631\u064a\u062a \u0641\u0627\u0634\u0648\u0646 \u062c\u0631\u0648\u0628 \u0644\u0644\u0627\u0633\u062a\u062b\u0645\u0627\u0631\u0627\u062a \u0627\u0644\u062a\u062c\u0627\u0631\u064a\u0629 \u0648\u0627\u0644\u0635\u0646\u0627\u0639\u064a\u0629 (CFGH.CA) \u0646\u0645\u0648\u0630\u062c \u0627\u0641\u0635\u0627\u062d \u0628\u062e\u0635\u0648\u0635 \u0645\u062c\u0644\u0633 \u0627\u0644\u0627\u062f\u0627\u0631\u0629 \u0648\u0647\u064a\u0643\u0644 \u0627\u0644\u0645\u0633\u0627\u0647\u0645\u064a\u0646|13/07/2026",
  "td:\u0644\u0648\u062a\u0633 \u0644\u0644\u062a\u0646\u0645\u064a\u0629 \u0648\u0627\u0644\u0627\u0633\u062a\u062b\u0645\u0627\u0631 \u0627\u0644\u0632\u0631\u0627\u0639\u0649 (LUTS.CA)  \u0646\u0645\u0648\u0630\u062c \u062a\u0642\u0631\u064a\u0631 \u0625\u0641\u0635\u0627\u062d \u0627\u0644\u0634\u0631\u0643\u0629 \u0639\u0646 \u0645\u062c\u0644\u0633 \u0627\u0644\u0625\u062f\u0627\u0631\u0629 \u0648\u0647\u064a\u0643\u0644 \u0627\u0644\u0645\u0633\u0627\u0647\u0645\u064a\u0646|14/07/2026",
  "td:\u0644\u064a\u0633\u064a\u0643\u0648 \u0645\u0635\u0631 (LCSW.CA) \u0628\u064a\u0627\u0646 \u0645\u0646 \u0627\u0644\u0647\u064a\u0626\u0629 \u0627\u0644\u0639\u0627\u0645\u0629 \u0644\u0644\u0631\u0642\u0627\u0628\u0629 \u0627\u0644\u0645\u0627\u0644\u064a\u0629|14/07/2026",
  "td:\u0645\u0633\u062a\u0634\u0641\u0649 \u0627\u0644\u0646\u0632\u0647\u0629 \u0627\u0644\u062f\u0648\u0644\u064a (NINH.CA) \u0627\u0633\u062a\u062f\u0631\u0627\u0643|14/07/2026",
  "td:\u0645\u0633\u062a\u0634\u0641\u0649 \u0627\u0644\u0646\u0632\u0647\u0647 \u0627\u0644\u062f\u0648\u0644\u064a (NINH.CA) - \u0646\u0645\u0648\u0630\u062c \u062a\u0642\u0631\u064a\u0631 \u0625\u0641\u0635\u0627\u062d \u0644\u0644\u0634\u0631\u0643\u0629 \u0639\u0646 \u0645\u062c\u0644\u0633 \u0627\u0644\u0625\u062f\u0627\u0631\u0629 \u0648\u0647\u064a\u0643\u0644 \u0627\u0644\u0645\u0633\u0627\u0647\u0645\u064a\u0646|13/07/2026",
  "td:\u0645\u0635\u0631\u0641 \u0623\u0628\u0648 \u0638\u0628\u0649 \u0627\u0644\u0627\u0633\u0644\u0627\u0645\u0649 - \u0645\u0635\u0631 (ADIB.CA) \u0646\u0645\u0648\u0630\u062c \u0627\u0641\u0635\u0627\u062d \u0628\u062e\u0635\u0648\u0635 \u0645\u062c\u0644\u0633 \u0627\u0644\u0627\u062f\u0627\u0631\u0629 \u0648\u0647\u064a\u0643\u0644 \u0627\u0644\u0645\u0633\u0627\u0647\u0645\u064a\u0646|13/07/2026",
  "td:\u0648\u062b\u0627\u0626\u0642 \u0635\u0646\u062f\u0648\u0642 \u0627\u0633\u062a\u062b\u0645\u0627\u0631 \u0623\u0648\u062f\u0646 \u0644\u0644\u0627\u0633\u062a\u062b\u0645\u0627\u0631 \u0641\u064a \u0627\u0644\u0627\u0633\u0647\u0645 \u0627\u0644\u0645\u0635\u0631\u064a\u0629 -\u0643\u0633\u0628 (KASABF.CA) - \u0646\u0645\u0648\u0630\u062c \u062a\u0642\u0631\u064a\u0631 \u0625\u0641\u0635\u0627\u062d \u0644\u0644\u0634\u0631\u0643\u0629 \u0639\u0646 \u0645\u062c\u0644\u0633 \u0627\u0644\u0625\u062f\u0627\u0631\u0629 \u0648\u0647\u064a\u0643\u0644 \u0627\u0644\u0645\u0633\u0627\u0647\u0645\u064a\u0646|13/07/2026",
  "td:\u064a\u0648 \u0644\u0644\u062a\u0645\u0648\u064a\u0644 \u0627\u0644\u0627\u0633\u062a\u0647\u0644\u0627\u0643\u0649 (VALU.CA) \u0646\u0645\u0648\u0630\u062c \u0627\u0641\u0635\u0627\u062d \u0628\u062e\u0635\u0648\u0635 \u0645\u062c\u0644\u0633 \u0627\u0644\u0627\u062f\u0627\u0631\u0629 \u0648\u0647\u064a\u0643\u0644 \u0627\u0644\u0645\u0633\u0627\u0647\u0645\u064a\u0646|14/07/2026"
