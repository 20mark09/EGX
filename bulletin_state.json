  "td:\u0645\u0637\u0627\u062d\u0646 \u0645\u0635\u0631 \u0627\u0644\u0648\u0633\u0637\u064a (CEFM.CA) \n\u0645\u0644\u062e\u0635 \u0642\u0631\u0627\u0631\u0627\u062a \u0627\u062c\u062a\u0645\u0627\u0639 \u0645\u062c\u0644\u0633 \u0627\u0644\u0627\u062f\u0627\u0631\u0629|19/07/2026",
