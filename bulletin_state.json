[
  "td:\u0623\u0648 \u0628\u0649 \u0627\u0644\u0645\u0627\u0644\u064a\u0629 \u0627\u0644\u0642\u0627\u0628\u0636\u0629 (OFH.CA) \u0646\u0645\u0648\u0630\u062c \u0627\u0641\u0635\u0627\u062d \u0628\u062e\u0635\u0648\u0635 \u0645\u062c\u0644\u0633 \u0627\u0644\u0627\u062f\u0627\u0631\u0629 \u0648\u0647\u064a\u0643\u0644 \u0627\u0644\u0645\u0633\u0627\u0647\u0645\u064a\u0646|15/07/2026",
