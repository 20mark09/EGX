  "td:\u0633\u0646\u062f\u0627\u062a \u0643\u0627\u0628\u064a\u062a\u0627\u0644 \u0644\u0644\u062a\u0648\u0631\u064a\u0642 \u0627\u0644\u0627\u0635\u062f\u0627\u0631 \u0627\u0644\u0631\u0627\u0628\u0639 \u0645\u0646 \u0627\u0644\u0628\u0631\u0646\u0627\u0645\u062c \u0627\u0644\u0633\u0627\u062f\u0633 \u0627\u0644\u0634\u0631\u064a\u062d\u0629 \u062f \u062f\u064a\u0633\u0645\u0628\u0631 2031 (EGBCPSC4P6DCV) \u064a\u0639\u0644\u0646 \u0639\u0646 \u062a\u0648\u0632\u064a\u0639 \u0643\u0648\u0628\u0648\u0646 \u0627\u0644\u0633\u0646\u062f \u0631\u0642\u0645 (16)|19/07/2026",
  "td:\u0633\u0646\u062f\u0627\u062a \u0643\u0627\u0628\u064a\u062a\u0627\u0644 \u0644\u0644\u062a\u0648\u0631\u064a\u0642 \u0627\u0644\u0627\u0635\u062f\u0627\u0631 \u0627\u0644\u0633\u0627\u062f\u0633 \u0627\u0644\u0628\u0631\u0646\u0627\u0645\u062c \u0627\u0644\u0633\u0627\u062f\u0633 \u0634\u0631\u064a\u062d\u0629 \u0623 \u0645\u0627\u064a\u0648 2027 (EGBCPSC6P6ACV) \u064a\u0639\u0644\u0646 \u0639\u0646 \u062a\u0648\u0632\u064a\u0639 \u0643\u0648\u0628\u0648\u0646 \u0627\u0644\u0633\u0646\u062f \u0631\u0642\u0645 (2)|19/07/2026",
  "td:\u0633\u0646\u062f\u0627\u062a \u0643\u0627\u0628\u064a\u062a\u0627\u0644 \u0644\u0644\u062a\u0648\u0631\u064a\u0642 \u0627\u0644\u0627\u0635\u062f\u0627\u0631 \u0627\u0644\u0633\u0627\u062f\u0633 \u0627\u0644\u0628\u0631\u0646\u0627\u0645\u062c \u0627\u0644\u0633\u0627\u062f\u0633 \u0634\u0631\u064a\u062d\u0629 \u0628 \u0627\u0628\u0631\u064a\u0644 2029 (EGBCPSC6P6BCV) \u064a\u0639\u0644\u0646 \u0639\u0646 \u062a\u0648\u0632\u064a\u0639 \u0643\u0648\u0628\u0648\u0646 \u0627\u0644\u0633\u0646\u062f \u0631\u0642\u0645 (2)|19/07/2026",
  "td:\u0633\u0646\u062f\u0627\u062a \u0643\u0627\u0628\u064a\u062a\u0627\u0644 \u0644\u0644\u062a\u0648\u0631\u064a\u0642 \u0627\u0644\u0627\u0635\u062f\u0627\u0631 \u0627\u0644\u0633\u0627\u062f\u0633 \u0627\u0644\u0628\u0631\u0646\u0627\u0645\u062c \u0627\u0644\u0633\u0627\u062f\u0633 \u0634\u0631\u064a\u062d\u0629 \u062c \u0627\u0628\u0631\u064a\u0644 2031 (EGBCPSC6P6CCV) \u064a\u0639\u0644\u0646 \u0639\u0646 \u062a\u0648\u0632\u064a\u0639 \u0643\u0648\u0628\u0648\u0646 \u0627\u0644\u0633\u0646\u062f \u0631\u0642\u0645 (2)|19/07/2026",
  "td:\u0633\u0646\u062f\u0627\u062a \u0643\u0627\u0628\u064a\u062a\u0627\u0644 \u0644\u0644\u062a\u0648\u0631\u064a\u0642 \u0627\u0644\u0627\u0635\u062f\u0627\u0631 \u0627\u0644\u0633\u0627\u062f\u0633 \u0627\u0644\u0628\u0631\u0646\u0627\u0645\u062c \u0627\u0644\u0633\u0627\u062f\u0633 \u0634\u0631\u064a\u062d\u0629 \u062f \u064a\u0646\u0627\u064a\u0631 2033 (EGBCPSC6P6DCV) \u064a\u0639\u0644\u0646 \u0639\u0646 \u062a\u0648\u0632\u064a\u0639 \u0643\u0648\u0628\u0648\u0646 \u0627\u0644\u0633\u0646\u062f \u0631\u0642\u0645 (2)|19/07/2026",
  "td:\u0639\u0628\u0648\u0631 \u0644\u0627\u0646\u062f \u0644\u0644\u0635\u0646\u0627\u0639\u0627\u062a \u0627\u0644\u063a\u0630\u0627\u0626\u064a\u0629 (OLFI.CA) - \u0646\u0645\u0648\u0630\u062c \u062a\u0642\u0631\u064a\u0631 \u0625\u0641\u0635\u0627\u062d \u0644\u0644\u0634\u0631\u0643\u0629 \u0639\u0646 \u0645\u062c\u0644\u0633 \u0627\u0644\u0625\u062f\u0627\u0631\u0629 \u0648\u0647\u064a\u0643\u0644 \u0627\u0644\u0645\u0633\u0627\u0647\u0645\u064a\u0646|19/07/2026",
  "td:\u0643\u0631\u0633\u062a\u0645\u0627\u0631\u0643 \u0644\u0644\u0645\u0642\u0627\u0648\u0644\u0627\u062a \u0648\u0627\u0644\u062a\u0637\u0648\u064a\u0631 \u0627\u0644\u0639\u0642\u0627\u0631\u064a (CRST.CA) \u0642\u0631\u0627\u0631\u0627\u062a \u0645\u062c\u0644\u0633 \u0627\u062f\u0627\u0631\u0629 \u0627\u0644\u0634\u0631\u0643\u0629|19/07/2026",
  "td:\u0644\u0648\u062a\u0633 \u0644\u0644\u062a\u0646\u0645\u064a\u0629 \u0648\u0627\u0644\u0627\u0633\u062a\u062b\u0645\u0627\u0631 \u0627\u0644\u0632\u0631\u0627\u0639\u0649 (LUTS.CA) \u0628\u064a\u0627\u0646|19/07/2026",
