[
  "td:(\u0645\u0635\u0631 \u0627\u0646\u062a\u0631\u0643\u0648\u0646\u0646\u062a\u0627\u0644 \u0644\u0635\u0646\u0627\u0639\u0629 \u0627\u0644\u062c\u0631\u0627\u0646\u064a\u062a \u0648\u0627\u0644\u0631\u062e\u0627\u0645 (\u0627\u064a\u062c\u0649 \u0633\u062a\u0648\u0646 (MISR.CA) - \u0646\u0645\u0648\u0630\u062c \u062a\u0642\u0631\u064a\u0631 \u0625\u0641\u0635\u0627\u062d \u0644\u0644\u0634\u0631\u0643\u0629 \u0639\u0646 \u0645\u062c\u0644\u0633 \u0627\u0644\u0625\u062f\u0627\u0631\u0629 \u0648\u0647\u064a\u0643\u0644 \u0627\u0644\u0645\u0633\u0627\u0647\u0645\u064a\u0646 (\u0633\u0648\u0642 \u0627\u0644\u0634\u0631\u0643\u0627\u062a \u0627\u0644\u0635\u063a\u064a\u0631\u0629 \u0648\u0627\u0644\u0645\u062a\u0648\u0633\u0637\u0629)|13/07/2026",
  "td:\u0625\u062a\u0627\u062d\u0629 \u062a\u062f\u0627\u0648\u0644 \u0627\u0630\u0648\u0646 \u0627\u0644\u062e\u0632\u0627\u0646\u0629 \u0627\u0644\u0645\u0635\u0631\u064a\u0629|13/07/2026",
  "td:\u0625\u0639\u0644\u0627\u0646 \u0644\u062c\u0645\u064a\u0639 \u0627\u0644\u0645\u062a\u0639\u0627\u0645\u0644\u064a\u0646|13/07/2026",
  "td:\u0627\u0631\u0627\u0628 \u0644\u0644\u062a\u0646\u0645\u064a\u0629 \u0648\u0627\u0644\u0627\u0633\u062a\u062b\u0645\u0627\u0631 \u0627\u0644\u0639\u0642\u0627\u0631\u064a (ADRI.CA) - \u0646\u0645\u0648\u0630\u062c \u062a\u0642\u0631\u064a\u0631 \u0625\u0641\u0635\u0627\u062d \u0644\u0644\u0634\u0631\u0643\u0629 \u0639\u0646 \u0645\u062c\u0644\u0633 \u0627\u0644\u0625\u062f\u0627\u0631\u0629 \u0648\u0647\u064a\u0643\u0644 \u0627\u0644\u0645\u0633\u0627\u0647\u0645\u064a\u0646 (\u0633\u0648\u0642 \u0627\u0644\u0634\u0631\u0643\u0627\u062a \u0627\u0644\u0635\u063a\u064a\u0631\u0629 \u0648\u0627\u0644\u0645\u062a\u0648\u0633\u0637\u0629)|13/07/2026",
  "td:\u0627\u0644\u0627\u0644\u0648\u0645\u0646\u064a\u0648\u0645 \u0627\u0644\u0639\u0631\u0628\u064a\u0629 (ALUM.CA) - \u0646\u0645\u0648\u0630\u062c \u062a\u0642\u0631\u064a\u0631 \u0625\u0641\u0635\u0627\u062d \u0644\u0644\u0634\u0631\u0643\u0629 \u0639\u0646 \u0645\u062c\u0644\u0633 \u0627\u0644\u0625\u062f\u0627\u0631\u0629 \u0648\u0647\u064a\u0643\u0644 \u0627\u0644\u0645\u0633\u0627\u0647\u0645\u064a\u0646|13/07/2026",
  "td:\u0627\u0644\u062e\u062f\u0645\u0627\u062a \u0627\u0644\u0645\u0644\u0627\u062d\u064a\u0629 \u0648\u0627\u0644\u0628\u062a\u0631\u0648\u0644\u064a\u0629  - \u0645\u0627\u0631\u064a\u062f\u064a\u0641 (MOIL.CA) - \u0646\u0645\u0648\u0630\u062c \u062a\u0642\u0631\u064a\u0631 \u0625\u0641\u0635\u0627\u062d \u0644\u0644\u0634\u0631\u0643\u0629 \u0639\u0646 \u0645\u062c\u0644\u0633 \u0627\u0644\u0625\u062f\u0627\u0631\u0629 \u0648\u0647\u064a\u0643\u0644 \u0627\u0644\u0645\u0633\u0627\u0647\u0645\u064a\u0646|13/07/2026",
  "td:\u0627\u0644\u062f\u0644\u062a\u0627 \u0644\u0644\u062a\u0623\u0645\u064a\u0646 (DEIN.CA) \u0628\u064a\u0627\u0646 \u0645\u0646 \u0627\u0644\u0634\u0631\u0643\u0629|13/07/2026",
  "td:\u0627\u0644\u0633\u0639\u0648\u062f\u064a\u0629 \u0627\u0644\u0645\u0635\u0631\u064a\u0629 \u0644\u0644\u0627\u0633\u062a\u062b\u0645\u0627\u0631 \u0648\u0627\u0644\u062a\u0645\u0648\u064a\u0644 (SEIG.CA  SEIGA.CA)  \u0646\u0645\u0648\u0630\u062c \u062a\u0642\u0631\u064a\u0631 \u0625\u0641\u0635\u0627\u062d \u0627\u0644\u0634\u0631\u0643\u0629 \u0639\u0646 \u0645\u062c\u0644\u0633 \u0627\u0644\u0625\u062f\u0627\u0631\u0629 \u0648\u0647\u064a\u0643\u0644 \u0627\u0644\u0645\u0633\u0627\u0647\u0645\u064a\u0646|13/07/2026",
  "td:\u0627\u0644\u0635\u0646\u0627\u0639\u0627\u062a \u0627\u0644\u063a\u0630\u0627\u0626\u064a\u0629 \u0627\u0644\u0639\u0631\u0628\u064a\u0629-\u062f\u0648\u0645\u062a\u0649 (DOMT.CA) - \u0646\u0645\u0648\u0630\u062c \u062a\u0642\u0631\u064a\u0631 \u0625\u0641\u0635\u0627\u062d \u0644\u0644\u0634\u0631\u0643\u0629 \u0639\u0646 \u0645\u062c\u0644\u0633 \u0627\u0644\u0625\u062f\u0627\u0631\u0629 \u0648\u0647\u064a\u0643\u0644 \u0627\u0644\u0645\u0633\u0627\u0647\u0645\u064a\u0646|13/07/2026",
  "td:\u0627\u0644\u0639\u0627\u0645\u0629 \u0644\u0627\u0633\u062a\u0635\u0644\u0627\u062d \u0627\u0644\u0627\u0631\u0627\u0636\u064a \u0648 \u0627\u0644\u062a\u0646\u0645\u064a\u0629 \u0648 \u0627\u0644\u062a\u0639\u0645\u064a\u0631 (AALR.CA) - \u0645\u062d\u0636\u0631 \u0625\u062c\u062a\u0645\u0627\u0639 \u0627\u0644\u062c\u0645\u0639\u064a\u0629 \u0627\u0644\u0639\u0627\u0645\u0629 \u0627\u0644\u0639\u0627\u062f\u064a\u0629 \u0627\u0644\u0645\u0646\u0639\u0642\u062f\u0629 \u0641\u064a 21/06/2026 (\u0645\u0648\u062b\u0642)|13/07/2026",
  "td:\u0627\u0644\u0639\u0627\u0645\u0629 \u0644\u0644\u0635\u0648\u0627\u0645\u0639 \u0648\u0627\u0644\u062a\u062e\u0632\u064a\u0646 (GSSC.CA) - \u0646\u0645\u0648\u0630\u062c \u062a\u0642\u0631\u064a\u0631 \u0625\u0641\u0635\u0627\u062d \u0627\u0644\u0634\u0631\u0643\u0629 \u0639\u0646 \u0645\u062c\u0644\u0633 \u0627\u0644\u0625\u062f\u0627\u0631\u0629 \u0648\u0647\u064a\u0643\u0644 \u0627\u0644\u0645\u0633\u0627\u0647\u0645\u064a\u0646|13/07/2026",
  "td:\u0627\u0644\u0639\u0631\u0628\u064a\u0629 \u0644\u0644\u0635\u0646\u0627\u0639\u0627\u062a \u0627\u0644\u0647\u0646\u062f\u0633\u064a\u0629 (EEII.CA) - \u0646\u0645\u0648\u0630\u062c \u062a\u0642\u0631\u064a\u0631 \u0625\u0641\u0635\u0627\u062d \u0644\u0644\u0634\u0631\u0643\u0629 \u0639\u0646 \u0645\u062c\u0644\u0633 \u0627\u0644\u0625\u062f\u0627\u0631\u0629 \u0648\u0647\u064a\u0643\u0644 \u0627\u0644\u0645\u0633\u0627\u0647\u0645\u064a\u0646|13/07/2026",
  "td:\u0627\u0644\u0645\u0635\u0631\u064a\u0629 \u0627\u0644\u0639\u0631\u0628\u064a\u0629 (\u062b\u0645\u0627\u0631) \u0644\u062a\u062f\u0627\u0648\u0644 \u0627\u0644\u0627\u0648\u0631\u0627\u0642 \u0627\u0644\u0645\u0627\u0644\u064a\u0629 \u0648\u0627\u0644\u0633\u0646\u062f\u0627\u062a (EASB.CA) \u0645\u062d\u0636\u0631 \u0625\u062c\u062a\u0645\u0627\u0639 \u0627\u0644\u062c\u0645\u0639\u064a\u0629 \u0627\u0644\u0639\u0627\u0645\u0629 \u0627\u0644\u0639\u0627\u062f\u064a\u0629 \u0648 \u063a\u064a\u0631 \u0627\u0644\u0639\u0627\u062f\u064a\u0629 \u0627\u0644\u062a\u0649 \u0627\u0646\u0639\u0642\u062f\u062a \u0641\u0649 2026/07/06 (\u063a\u064a\u0631 \u0645\u0648\u062b\u0642)|13/07/2026",
  "td:\u0627\u0644\u0646\u0635\u0631 \u0644\u0644\u0623\u0639\u0645\u0627\u0644 \u0627\u0644\u0645\u062f\u0646\u064a\u0629 (NCCW.CA) \u0646\u0645\u0648\u0630\u062c \u062a\u0642\u0631\u064a\u0631 \u0625\u0641\u0635\u0627\u062d \u0627\u0644\u0634\u0631\u0643\u0629 \u0639\u0646 \u0645\u062c\u0644\u0633 \u0627\u0644\u0625\u062f\u0627\u0631\u0629 \u0648\u0647\u064a\u0643\u0644 \u0627\u0644\u0645\u0633\u0627\u0647\u0645\u064a\u0646|13/07/2026",
  "td:\u0627\u0644\u0648\u0637\u0646\u064a\u0629 \u0644\u0644\u0627\u0633\u0643\u0627\u0646 \u0644\u0644\u0646\u0642\u0627\u0628\u0627\u062a \u0627\u0644\u0645\u0647\u0646\u064a\u0629 (NHPS.CA) \u0628\u064a\u0627\u0646|13/07/2026",
  "td:\u062a\u0645 \u0627\u064a\u0642\u0627\u0641 \u0627\u0644\u0648\u0631\u0642\u0629 \u0627\u0644\u0645\u0627\u0644\u064a\u0629 - EGS38391C016 -  \u0627\u0644\u0642\u0627\u0647\u0631\u0629 \u0644\u0644\u0627\u062f\u0648\u064a\u0629 \u0648\u0627\u0644\u0635\u0646\u0627\u0639\u0627\u062a \u0627\u0644\u0643\u064a\u0645\u0627\u0648\u064a\u0629 \u0644\u0645\u062f\u0629 10 \u062f\u0642\u0627\u0626\u0642 \u0644\u062a\u062c\u0627\u0648\u0632\u0647\u0627 \u0646\u0633\u0628\u0629 10 %|13/07/2026",
  "td:\u062a\u0645 \u0627\u064a\u0642\u0627\u0641 \u0627\u0644\u0648\u0631\u0642\u0629 \u0627\u0644\u0645\u0627\u0644\u064a\u0629 - EGS67331C016 -  \u062a\u0627\u064a\u0643\u0648\u0646 \u0627\u0646\u0641\u0633\u062a\u0645\u0646\u062a\u0633 \u0647\u0648\u0644\u062f\u0646\u062c \u0644\u0645\u062f\u0629 10 \u062f\u0642\u0627\u0626\u0642 \u0644\u062a\u062c\u0627\u0648\u0632\u0647\u0627 \u0646\u0633\u0628\u0629 10 %|13/07/2026",
  "td:\u062a\u0645 \u0627\u064a\u0642\u0627\u0641 \u0627\u0644\u0648\u0631\u0642\u0629 \u0627\u0644\u0645\u0627\u0644\u064a\u0629 - EGS69261C013 -  \u062c\u0631\u0627\u0646\u062f \u0627\u0646\u0641\u0633\u062a\u0645\u0646\u062a \u0627\u0644\u0642\u0627\u0628\u0636\u0629 \u0644\u0644\u0627\u0633\u062a\u062b\u0645\u0627\u0631\u0627\u062a \u0627\u0644\u0645\u0627\u0644\u064a\u0629 \u0644\u0645\u062f\u0629 10 \u062f\u0642\u0627\u0626\u0642 \u0644\u062a\u062c\u0627\u0648\u0632\u0647\u0627 \u0646\u0633\u0628\u0629 10 %|13/07/2026",
  "td:\u062c\u0631\u0627\u0646\u062f \u0627\u0646\u0641\u0633\u062a\u0645\u0646\u062a \u0627\u0644\u0642\u0627\u0628\u0636\u0629 \u0644\u0644\u0627\u0633\u062a\u062b\u0645\u0627\u0631\u0627\u062a \u0627\u0644\u0645\u0627\u0644\u064a\u0629 (GRCA.CA) - \u0646\u0645\u0648\u0630\u062c \u062a\u0642\u0631\u064a\u0631 \u0625\u0641\u0635\u0627\u062d \u0644\u0644\u0634\u0631\u0643\u0629 \u0639\u0646 \u0645\u062c\u0644\u0633 \u0627\u0644\u0625\u062f\u0627\u0631\u0629 \u0648\u0647\u064a\u0643\u0644 \u0627\u0644\u0645\u0633\u0627\u0647\u0645\u064a\u0646|13/07/2026",
  "td:\u062c\u064a\u062a\u0643\u0633 \u0644\u0644\u0627\u0633\u062a\u062b\u0645\u0627\u0631\u0627\u062a \u0627\u0644\u062a\u062c\u0627\u0631\u064a\u0629 \u0648\u0627\u0644\u0635\u0646\u0627\u0639\u064a\u0629 (GTEX.CA) \u0646\u0645\u0648\u0630\u062c \u0627\u0641\u0635\u0627\u062d \u0628\u062e\u0635\u0648\u0635 \u0645\u062c\u0644\u0633 \u0627\u0644\u0627\u062f\u0627\u0631\u0629 \u0648\u0647\u064a\u0643\u0644 \u0627\u0644\u0645\u0633\u0627\u0647\u0645\u064a\u0646|13/07/2026",
  "td:\u062f\u0627\u064a\u0633 \u0644\u0644\u0645\u0644\u0627\u0628\u0633 \u0627\u0644\u062c\u0627\u0647\u0632\u0629 (DSCW.CA) \u0646\u0645\u0648\u0630\u062c \u0627\u0641\u0635\u0627\u062d \u0628\u062e\u0635\u0648\u0635 \u0645\u062c\u0644\u0633 \u0627\u0644\u0627\u062f\u0627\u0631\u0629 \u0648\u0647\u064a\u0643\u0644 \u0627\u0644\u0645\u0633\u0627\u0647\u0645\u064a\u0646|13/07/2026",
  "td:\u0631\u0645\u0643\u0648 \u0644\u0627\u0646\u0634\u0627\u0621 \u0627\u0644\u0642\u0631\u0649 \u0627\u0644\u0633\u064a\u0627\u062d\u064a\u0647 (RTVC.CA) - \u0646\u0645\u0648\u0630\u062c \u062a\u0642\u0631\u064a\u0631 \u0625\u0641\u0635\u0627\u062d \u0644\u0644\u0634\u0631\u0643\u0629 \u0639\u0646 \u0645\u062c\u0644\u0633 \u0627\u0644\u0625\u062f\u0627\u0631\u0629 \u0648\u0647\u064a\u0643\u0644 \u0627\u0644\u0645\u0633\u0627\u0647\u0645\u064a\u0646|13/07/2026",
  "td:\u0632\u0647\u0631\u0627\u0621 \u0627\u0644\u0645\u0639\u0627\u062f\u064a \u0644\u0644\u0627\u0633\u062a\u062b\u0645\u0627\u0631 \u0648\u0627\u0644\u062a\u0639\u0645\u064a\u0631 (ZMID.CA) - \u062a\u0642\u0631\u064a\u0631 \u0627\u0644\u062c\u0647\u0627\u0632 \u0627\u0644\u0645\u0631\u0643\u0632\u0649 \u0644\u0644\u0645\u062d\u0627\u0633\u0628\u0627\u062a|13/07/2026",
  "td:\u0632\u064a\u0627\u062f\u0629 \u0642\u064a\u0645\u0629 \u0627\u0644\u0627\u0635\u062f\u0627\u0631 \u0641\u064a \u0623\u0630\u0648\u0646 \u0627\u0644\u062e\u0632\u0627\u0646\u0629 \u0627\u0644\u0645\u0635\u0631\u064a\u0629|13/07/2026",
  "td:\u0633\u0639\u0631 \u0627\u0644\u0643\u0648\u0628\u0648\u0646 \u0631\u0642\u0645 (7)|13/07/2026",
  "td:\u0633\u0646\u062f\u0627\u062a \u0627\u0644\u062a\u0639\u0645\u064a\u0631 \u0644\u0644\u062a\u0648\u0631\u064a\u0642 (EGBETSC1P4ACV  EGBETSC1P4BCV  EGBETSC1P4CCV) \u0628\u064a\u0627\u0646 \u0645\u0646 \u0627\u0644\u0634\u0631\u0643\u0629|13/07/2026",
  "td:\u0633\u0646\u062f\u0627\u062a \u0627\u0644\u0645\u0635\u0631\u064a\u0629 \u0644\u0644\u062a\u0648\u0631\u064a\u0642 \u0627\u0644\u0627\u0635\u062f\u0627\u0631 \u0627\u0644\u062b\u0627\u0644\u062b \u0628\u0631\u0646\u0627\u0645\u062c \u062b\u0627\u0646\u064a \u0627\u0644\u0634\u0631\u064a\u062d\u0629 \u0628 \u062f\u064a\u0633\u0645\u0628\u0631 2026 (EGBECSC3P2BCF) \u064a\u0639\u0644\u0646 \u0639\u0646 \u062a\u0648\u0632\u064a\u0639 \u0643\u0648\u0628\u0648\u0646 \u0627\u0644\u0633\u0646\u062f \u0631\u0642\u0645 (6)|13/07/2026",
  "td:\u0633\u0646\u062f\u0627\u062a \u0627\u0644\u0645\u0635\u0631\u064a\u0629 \u0644\u0644\u062a\u0648\u0631\u064a\u0642 \u0627\u0644\u0627\u0635\u062f\u0627\u0631 \u0627\u0644\u062b\u0627\u0644\u062b \u0628\u0631\u0646\u0627\u0645\u062c \u062b\u0627\u0646\u064a \u0627\u0644\u0634\u0631\u064a\u062d\u0629 \u062c \u064a\u0648\u0644\u064a\u0648 2027 (EGBECSC3P2CCF) \u064a\u0639\u0644\u0646 \u0639\u0646 \u062a\u0648\u0632\u064a\u0639 \u0643\u0648\u0628\u0648\u0646 \u0627\u0644\u0633\u0646\u062f \u0631\u0642\u0645 (6)|13/07/2026",
  "td:\u0633\u0646\u062f\u0627\u062a \u062c\u0644\u0648\u0628\u0627\u0644 \u0643\u0648\u0631\u0628 \u0644\u0644\u062a\u0648\u0631\u064a\u0642 \u0627\u0644\u0627\u0635\u062f\u0627\u0631 \u0627\u0644\u0627\u0648\u0644 \u0627\u0644\u0628\u0631\u0646\u0627\u0645\u062c \u0627\u0644\u062b\u0627\u0644\u062b \u0627\u0644\u0634\u0631\u064a\u062d\u0629  \u0623 \u0645\u0627\u064a\u0648 2028 (EGBGLSC1P3ACV) \u064a\u0639\u0644\u0646 \u0639\u0646 \u062a\u0648\u0632\u064a\u0639 \u0643\u0648\u0628\u0648\u0646 \u0627\u0644\u0633\u0646\u062f \u0631\u0642\u0645 (2)|13/07/2026",
  "td:\u0633\u0646\u062f\u0627\u062a \u062c\u0644\u0648\u0628\u0627\u0644 \u0643\u0648\u0631\u0628 \u0644\u0644\u062a\u0648\u0631\u064a\u0642 \u0627\u0644\u0627\u0635\u062f\u0627\u0631 \u0627\u0644\u0627\u0648\u0644 \u0627\u0644\u0628\u0631\u0646\u0627\u0645\u062c \u0627\u0644\u062b\u0627\u0644\u062b \u0627\u0644\u0634\u0631\u064a\u062d\u0629 \u0628 \u0645\u0627\u064a\u0648 2029 (EGBGLSC1P3BCV) \u064a\u0639\u0644\u0646 \u0639\u0646 \u062a\u0648\u0632\u064a\u0639 \u0643\u0648\u0628\u0648\u0646 \u0627\u0644\u0633\u0646\u062f \u0631\u0642\u0645 (2)|13/07/2026",
  "td:\u0633\u0646\u062f\u0627\u062a \u062c\u0644\u0648\u0628\u0627\u0644 \u0643\u0648\u0631\u0628 \u0644\u0644\u062a\u0648\u0631\u064a\u0642 \u0627\u0644\u0627\u0635\u062f\u0627\u0631 \u0627\u0644\u062b\u0627\u0646\u0649  \u0627\u0644\u0628\u0631\u0646\u0627\u0645\u062c \u0627\u0644\u0627\u0648\u0644  \u0627\u0644\u0634\u0631\u064a\u062d\u0629 \u062c \u0627\u0643\u062a\u0648\u0628\u0631 2027 (EGGLOB2P1C=CA) \u064a\u0639\u0644\u0646 \u0639\u0646 \u062a\u0648\u0632\u064a\u0639 \u0643\u0648\u0628\u0648\u0646 \u0627\u0644\u0633\u0646\u062f \u0631\u0642\u0645 (2)|13/07/2026",
  "td:\u0633\u0646\u062f\u0627\u062a \u0643\u0648\u0631\u0628\u0644\u064a\u0633 \u0644\u0644\u062a\u0623\u062c\u064a\u0631 \u0627\u0644\u062a\u0645\u0648\u064a\u0644\u0649 \u0627\u0644\u0627\u0635\u062f\u0627\u0631 \u0627\u0644\u0627\u0648\u0644 \u0628\u0631\u0646\u0627\u0645\u062c \u0627\u0648\u0644 \u0646\u0648\u0641\u0645\u0628\u0631 2026 (EGBCORP1P1CF) \u064a\u0639\u0644\u0646 \u0639\u0646 \u062a\u0648\u0632\u064a\u0639 \u0643\u0648\u0628\u0648\u0646 \u0627\u0644\u0633\u0646\u062f \u0631\u0642\u0645 (3)|13/07/2026",
  "td:\u0633\u064a\u062f\u0649 \u0643\u0631\u064a\u0631 \u0644\u0644\u0628\u062a\u0631\u0648\u0643\u064a\u0645\u0627\u0648\u064a\u0627\u062a - \u0633\u064a\u062f\u0628\u0643 (SKPC.CA) - \u0646\u0645\u0648\u0630\u062c \u062a\u0642\u0631\u064a\u0631 \u0625\u0641\u0635\u0627\u062d \u0644\u0644\u0634\u0631\u0643\u0629 \u0639\u0646 \u0645\u062c\u0644\u0633 \u0627\u0644\u0625\u062f\u0627\u0631\u0629 \u0648\u0647\u064a\u0643\u0644 \u0627\u0644\u0645\u0633\u0627\u0647\u0645\u064a\u0646|13/07/2026",
  "td:\u0635\u0643\u0648\u0643 \u0627\u0644\u0643\u0627\u0646 \u0641\u0627\u064a\u0646\u0627\u0646\u0633 \u0635\u0643\u0648\u0643 \u0627\u0644\u0627\u0635\u062f\u0627\u0631 \u0627\u0644\u0627\u0648\u0644 \u0641\u0628\u0631\u0627\u064a\u0631 2030 (EGKALSK01CV) \u064a\u0639\u0644\u0646 \u0639\u0646 \u062a\u0648\u0632\u064a\u0639 \u0643\u0648\u0628\u0648\u0646 \u0627\u0644\u0633\u0646\u062f \u0631\u0642\u0645 (16)|13/07/2026",
  "td:\u0643\u0648\u0646\u0643\u0631\u064a\u062a \u0641\u0627\u0634\u0648\u0646 \u062c\u0631\u0648\u0628 \u0644\u0644\u0627\u0633\u062a\u062b\u0645\u0627\u0631\u0627\u062a \u0627\u0644\u062a\u062c\u0627\u0631\u064a\u0629 \u0648\u0627\u0644\u0635\u0646\u0627\u0639\u064a\u0629 (CFGH.CA) \u0646\u0645\u0648\u0630\u062c \u0627\u0641\u0635\u0627\u062d \u0628\u062e\u0635\u0648\u0635 \u0645\u062c\u0644\u0633 \u0627\u0644\u0627\u062f\u0627\u0631\u0629 \u0648\u0647\u064a\u0643\u0644 \u0627\u0644\u0645\u0633\u0627\u0647\u0645\u064a\u0646|13/07/2026",
  "td:\u0645\u0633\u062a\u0634\u0641\u0649 \u0627\u0644\u0646\u0632\u0647\u0647 \u0627\u0644\u062f\u0648\u0644\u064a (NINH.CA) - \u0646\u0645\u0648\u0630\u062c \u062a\u0642\u0631\u064a\u0631 \u0625\u0641\u0635\u0627\u062d \u0644\u0644\u0634\u0631\u0643\u0629 \u0639\u0646 \u0645\u062c\u0644\u0633 \u0627\u0644\u0625\u062f\u0627\u0631\u0629 \u0648\u0647\u064a\u0643\u0644 \u0627\u0644\u0645\u0633\u0627\u0647\u0645\u064a\u0646|13/07/2026",
  "td:\u0645\u0635\u0631\u0641 \u0623\u0628\u0648 \u0638\u0628\u0649 \u0627\u0644\u0627\u0633\u0644\u0627\u0645\u0649 - \u0645\u0635\u0631 (ADIB.CA) \u0646\u0645\u0648\u0630\u062c \u0627\u0641\u0635\u0627\u062d \u0628\u062e\u0635\u0648\u0635 \u0645\u062c\u0644\u0633 \u0627\u0644\u0627\u062f\u0627\u0631\u0629 \u0648\u0647\u064a\u0643\u0644 \u0627\u0644\u0645\u0633\u0627\u0647\u0645\u064a\u0646|13/07/2026",
  "td:\u0648\u062b\u0627\u0626\u0642 \u0635\u0646\u062f\u0648\u0642 \u0627\u0633\u062a\u062b\u0645\u0627\u0631 \u0623\u0648\u062f\u0646 \u0644\u0644\u0627\u0633\u062a\u062b\u0645\u0627\u0631 \u0641\u064a \u0627\u0644\u0627\u0633\u0647\u0645 \u0627\u0644\u0645\u0635\u0631\u064a\u0629 -\u0643\u0633\u0628 (KASABF.CA) - \u0646\u0645\u0648\u0630\u062c \u062a\u0642\u0631\u064a\u0631 \u0625\u0641\u0635\u0627\u062d \u0644\u0644\u0634\u0631\u0643\u0629 \u0639\u0646 \u0645\u062c\u0644\u0633 \u0627\u0644\u0625\u062f\u0627\u0631\u0629 \u0648\u0647\u064a\u0643\u0644 \u0627\u0644\u0645\u0633\u0627\u0647\u0645\u064a\u0646|13/07/2026"
]